# CryptoPro Charts — environment configuration
# Copy to ".env" (or set these in your shell/host) to enable SSO sign-in.
# With none set, the app runs single-user as an anonymous "guest".

# Public base URL of the deployment (used to build OAuth redirect URIs).
# Defaults to the request host when unset. Set in production behind a proxy.
# BASE_URL=https://charts.example.com

# Set to "production" to mark session cookies Secure (HTTPS only).
# NODE_ENV=production

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <BASE_URL>/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth ---
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: <BASE_URL>/api/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
