# CryptoPro Charts — environment configuration
# Copy to ".env" (or set these in your shell/host) as needed.
# Authentication is application-only (username + password); no third-party
# credentials are required.

# Port the server listens on (default 3000).
# PORT=3000

# Set to "production" to mark session cookies Secure (HTTPS only).
# NODE_ENV=production

# --- Supabase (Postgres) — accounts, sessions & layouts persistence ---
# Provide a Supabase/Postgres connection string. The Vercel Supabase
# integration injects these automatically; the server picks the first it finds
# (non-pooling preferred for this long-lived server). Tables are created on
# startup. Without a connection string the DB is disabled and the frontend
# falls back to browser localStorage.
# DBCRYPTOCHARTS_POSTGRES_URL_NON_POOLING="postgresql://...:5432/postgres?sslmode=require"
# DBCRYPTOCHARTS_POSTGRES_URL="postgresql://...:6543/postgres?sslmode=require"
# (generic fallbacks also accepted: POSTGRES_URL_NON_POOLING, POSTGRES_URL, DATABASE_URL)

# --- Server-side alert notifications (P1-6) ---
# The alert engine (requires the database above) evaluates alerts every 30s and
# can push notifications through these channels. Both are optional; triggered
# alerts always appear in the app's alert panel via polling.
# Telegram: create a bot with @BotFather, get your chat id from @userinfobot.
# TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
# TELEGRAM_CHAT_ID="123456789"
# Generic webhook: receives POST {source, message, alert} as JSON.
# ALERT_WEBHOOK_URL="https://example.com/hooks/cryptopro"
