# CryptoPro Charts — environment configuration
# Copy to ".env" (or set these in your shell/host) as needed.
# Authentication is application-only (username + password); no third-party
# credentials are required.

# Port the server listens on (default 3000).
# PORT=3000

# Set to "production" to mark session cookies Secure (HTTPS only).
# NODE_ENV=production

# --- Vercel Blob store (account persistence) ---
# When set, each user's account info is stored as a private JSON file in the
# blob store's "Users/" folder (Users/<username>.json). Without it, accounts
# fall back to local files under data/accounts/.
# Create a store + token at https://vercel.com/dashboard/stores
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
# BLOB_STORE_ID="store_..."
